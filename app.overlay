/*
 * Device tree overlay for DM860E stepper motor driver
 * GPIO pins for STEP, DIR, ENABLE control
 */

&gpio1 {
    status = "okay";
};

&uart20 {
    status = "okay";
    current-speed = <115200>;
};

/ {
    chosen {
        zephyr,console    = &uart20;
        zephyr,shell-uart = &uart20;
    };
};
